<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Emma Wailes — Service Design Leader</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #0A0A0A;
    --white: #FAFAF8;
    --grey-light: #F0EFEB;
    --grey-mid: #C8C7C2;
    --grey-text: #5C5C58;
    --accent: #9B1F6E;
    --accent-light: #F5E8F1;
    --serif: 'Cormorant Garamond', Georgia, serif;
    --sans: 'DM Sans', system-ui, sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; font-size: 16px; }

  body {
    background: var(--white);
    color: var(--black);
    font-family: var(--sans);
    font-weight: 300;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  /* ── PAGE SYSTEM ── */
  .page { display: none; min-height: 100vh; }
  .page.active { display: block; animation: fadeUp 0.5s ease forwards; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 60px;
    background: var(--white);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s, padding 0.3s;
  }

  nav.scrolled {
    border-color: var(--grey-mid);
    padding: 18px 60px;
  }

  .nav-logo {
    font-family: var(--serif);
    font-size: 1.25rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--black);
    cursor: pointer;
    text-decoration: none;
  }

  .nav-logo span {
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    gap: 40px;
    list-style: none;
    align-items: center;
  }

  .nav-links a {
    font-size: 0.82rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--grey-text);
    text-decoration: none;
    transition: color 0.2s;
    cursor: pointer;
  }

  .nav-links a:hover,
  .nav-links a.active { color: var(--black); }

  .nav-links a.active { color: var(--accent); }

  /* ── CONTAINERS ── */
  .container { max-width: 1160px; margin: 0 auto; padding: 0 60px; }
  .container-narrow { max-width: 780px; margin: 0 auto; padding: 0 60px; }

  /* ── HOME ── */
  .hero {
    padding: 180px 0 80px;
    border-bottom: 1px solid var(--grey-mid);
  }

  .hero-eyebrow {
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--accent);
  }

  .hero h1 {
    font-family: var(--serif);
    font-size: clamp(3.2rem, 7vw, 6rem);
    font-weight: 300;
    line-height: 1.06;
    letter-spacing: -0.01em;
    max-width: 820px;
    margin-bottom: 40px;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--accent);
    font-weight: 300;
  }

  .hero-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: end;
    padding-top: 20px;
  }

  .hero-desc {
    font-size: 1.1rem;
    line-height: 1.75;
    color: var(--grey-text);
    max-width: 440px;
  }

  .hero-meta {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: flex-end;
  }

  .hero-stat {
    text-align: right;
  }

  .hero-stat-number {
    font-family: var(--serif);
    font-size: 2.8rem;
    font-weight: 300;
    line-height: 1;
    color: var(--black);
  }

  .hero-stat-label {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--grey-text);
    margin-top: 4px;
  }

  /* ── SECTION LABELS ── */
  .section-label {
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--grey-text);
    margin-bottom: 48px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--grey-mid);
    max-width: 200px;
  }

  /* ── ABOUT STRIP ── */
  .about-strip {
    padding: 80px 0;
    border-bottom: 1px solid var(--grey-mid);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 80px;
    align-items: start;
  }

  .about-title {
    font-family: var(--serif);
    font-size: 2.6rem;
    font-weight: 300;
    line-height: 1.15;
    position: sticky;
    top: 120px;
  }

  .about-title em {
    font-style: italic;
    color: var(--accent);
  }

  .about-content p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--grey-text);
    margin-bottom: 24px;
  }

  .about-content p:last-of-type { margin-bottom: 0; }

  .about-content p strong {
    color: var(--black);
    font-weight: 500;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 36px;
  }

  .tag {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid var(--grey-mid);
    padding: 6px 14px;
    color: var(--grey-text);
    border-radius: 2px;
  }

  /* ── SELECTED WORK ── */
  .work-section {
    padding: 80px 0 0;
  }

  .work-list { }

  .work-item {
    display: grid;
    grid-template-columns: 72px 1fr auto;
    gap: 40px;
    align-items: center;
    padding: 44px 0;
    border-bottom: 1px solid var(--grey-mid);
    cursor: pointer;
    transition: background 0.2s;
    text-decoration: none;
    color: inherit;
  }

  .work-item:first-child { border-top: 1px solid var(--grey-mid); }

  .work-item:hover .work-arrow { transform: translateX(6px); color: var(--accent); }
  .work-item:hover .work-title { color: var(--accent); }

  .work-num {
    font-family: var(--serif);
    font-size: 1rem;
    color: var(--grey-mid);
    font-weight: 400;
    padding-top: 2px;
  }

  .work-info { }

  .work-client {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .work-title {
    font-family: var(--serif);
    font-size: 1.9rem;
    font-weight: 400;
    line-height: 1.2;
    transition: color 0.2s;
    margin-bottom: 12px;
  }

  .work-desc {
    font-size: 0.9rem;
    color: var(--grey-text);
    line-height: 1.6;
    max-width: 600px;
  }

  .work-meta {
    text-align: right;
    flex-shrink: 0;
  }

  .work-year {
    font-size: 0.8rem;
    color: var(--grey-text);
    display: block;
    margin-bottom: 4px;
  }

  .work-type {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--grey-mid);
  }

  .work-arrow {
    font-size: 1.4rem;
    color: var(--grey-mid);
    transition: transform 0.25s, color 0.2s;
    display: flex;
    align-items: center;
    margin-left: 32px;
  }

  /* ── CASE STUDY ── */
  .case-study { padding-top: 120px; }

  .case-back {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--grey-text);
    text-decoration: none;
    cursor: pointer;
    margin-bottom: 64px;
    transition: color 0.2s;
  }

  .case-back:hover { color: var(--accent); }

  .case-header {
    border-bottom: 1px solid var(--grey-mid);
    padding-bottom: 56px;
    margin-bottom: 80px;
  }

  .case-client {
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .case-client::before {
    content: '';
    width: 28px;
    height: 1px;
    background: var(--accent);
  }

  .case-h1 {
    font-family: var(--serif);
    font-size: clamp(2.4rem, 5vw, 4.2rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin-bottom: 40px;
    max-width: 820px;
  }

  .case-h1 em { font-style: italic; color: var(--accent); }

  .case-meta-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    padding-top: 40px;
    border-top: 1px solid var(--grey-light);
  }

  .case-meta-item { }

  .case-meta-label {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--grey-text);
    margin-bottom: 8px;
  }

  .case-meta-value {
    font-size: 0.92rem;
    color: var(--black);
    font-weight: 400;
    line-height: 1.4;
  }

  /* ── CASE BODY ── */
  .case-body {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 80px;
    margin-bottom: 100px;
  }

  .case-sidebar {
    position: sticky;
    top: 120px;
    height: fit-content;
  }

  .sidebar-nav { list-style: none; }

  .sidebar-nav li {
    margin-bottom: 16px;
  }

  .sidebar-nav a {
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--grey-text);
    text-decoration: none;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .sidebar-nav a::before {
    content: '';
    width: 16px;
    height: 1px;
    background: var(--grey-mid);
    transition: width 0.2s, background 0.2s;
    flex-shrink: 0;
  }

  .sidebar-nav a:hover { color: var(--accent); }
  .sidebar-nav a:hover::before { width: 24px; background: var(--accent); }

  .case-content { }

  .case-section {
    margin-bottom: 64px;
    padding-bottom: 64px;
    border-bottom: 1px solid var(--grey-light);
  }

  .case-section:last-child { border-bottom: none; }

  .case-section-label {
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
    font-weight: 400;
  }

  .case-section h2 {
    font-family: var(--serif);
    font-size: 2rem;
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: 24px;
  }

  .case-section p {
    font-size: 1rem;
    line-height: 1.85;
    color: var(--grey-text);
    margin-bottom: 20px;
  }

  .case-section p:last-child { margin-bottom: 0; }

  .case-section p strong { color: var(--black); font-weight: 500; }

  .pullquote {
    border-left: 2px solid var(--accent);
    padding: 4px 0 4px 28px;
    margin: 40px 0;
  }

  .pullquote p {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 300;
    line-height: 1.45;
    color: var(--black) !important;
    font-style: italic;
  }

  .pullquote cite {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--grey-text);
    display: block;
    margin-top: 12px;
    font-style: normal;
  }

  .outcome-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--grey-mid);
    border: 1px solid var(--grey-mid);
    margin: 32px 0;
  }

  .outcome-cell {
    background: var(--white);
    padding: 28px 24px;
  }

  .outcome-num {
    font-family: var(--serif);
    font-size: 2.4rem;
    font-weight: 300;
    line-height: 1;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .outcome-label {
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--grey-text);
  }

  .process-steps {
    margin: 32px 0;
  }

  .process-step {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 20px;
    margin-bottom: 28px;
    align-items: start;
  }

  .step-num {
    font-family: var(--serif);
    font-size: 1.1rem;
    color: var(--grey-mid);
    padding-top: 2px;
  }

  .step-content h4 {
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    margin-bottom: 6px;
  }

  .step-content p {
    font-size: 0.88rem;
    line-height: 1.7;
    color: var(--grey-text);
    margin: 0 !important;
  }

  /* ── HIGHLIGHTS BAND ── */
  .highlight-band {
    background: var(--black);
    color: var(--white);
    padding: 64px 0;
    margin: 0 0 80px;
  }

  .highlight-band .container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 60px;
  }

  .highlight-item {}

  .highlight-label {
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--grey-mid);
    margin-bottom: 12px;
  }

  .highlight-text {
    font-family: var(--serif);
    font-size: 1.3rem;
    font-weight: 300;
    line-height: 1.4;
    color: var(--white);
  }

  /* ── CONTACT ── */
  .contact-page {
    padding: 160px 0 120px;
    min-height: 100vh;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 120px;
    align-items: start;
  }

  .contact-left h1 {
    font-family: var(--serif);
    font-size: clamp(2.8rem, 5vw, 4.8rem);
    font-weight: 300;
    line-height: 1.08;
    margin-bottom: 32px;
  }

  .contact-left h1 em {
    font-style: italic;
    color: var(--accent);
  }

  .contact-left p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--grey-text);
    margin-bottom: 48px;
  }

  .contact-link {
    display: block;
    font-family: var(--serif);
    font-size: 1.4rem;
    font-weight: 300;
    color: var(--black);
    text-decoration: none;
    border-bottom: 1px solid var(--grey-mid);
    padding: 16px 0;
    transition: color 0.2s, border-color 0.2s;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .contact-link:hover { color: var(--accent); border-color: var(--accent); }

  .contact-link-arrow { font-size: 1rem; }

  .contact-right {
    padding-top: 20px;
  }

  .cv-block {
    background: var(--grey-light);
    padding: 48px 40px;
    margin-bottom: 40px;
  }

  .cv-block h3 {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: 12px;
  }

  .cv-block p {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--grey-text);
    margin-bottom: 28px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--accent);
    color: var(--white);
    font-family: var(--sans);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 14px 28px;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: background 0.2s, opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.85; }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border: 1px solid var(--black);
    color: var(--black);
    font-family: var(--sans);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 14px 28px;
    text-decoration: none;
    cursor: pointer;
    background: none;
    transition: background 0.2s, color 0.2s;
    margin-left: 12px;
  }

  .btn-secondary:hover { background: var(--black); color: var(--white); }

  .contact-details {
    border-top: 1px solid var(--grey-mid);
    padding-top: 32px;
  }

  .contact-detail-item {
    display: flex;
    justify-content: space-between;
    padding: 14px 0;
    border-bottom: 1px solid var(--grey-light);
    font-size: 0.88rem;
  }

  .contact-detail-label {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
    color: var(--grey-text);
  }

  .contact-detail-value { color: var(--black); }

  /* ── FOOTER ── */
  footer {
    border-top: 1px solid var(--grey-mid);
    padding: 32px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.78rem;
    color: var(--grey-text);
  }

  .footer-logo {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 500;
    color: var(--black);
  }

  .footer-logo span { color: var(--accent); }

  /* ── HERO CTAs ── */
  .hero-ctas {
    display: flex;
    align-items: center;
    gap: 0;
    margin-top: 48px;
    flex-wrap: wrap;
    gap: 12px;
  }

  .hero-ctas .btn-secondary { margin-left: 0; }

  /* ── RECOGNITION ── */
  .recognition-section {
    padding-bottom: 80px;
    border-bottom: 1px solid var(--grey-mid);
  }

  .awards-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--grey-mid);
    border: 1px solid var(--grey-mid);
  }

  .award-item {
    background: var(--white);
    padding: 36px 32px;
    display: flex;
    align-items: flex-start;
    gap: 20px;
  }

  .award-badge {
    flex-shrink: 0;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 2px;
    margin-top: 3px;
  }

  .award-badge.gold {
    background: #F5E8C0;
    color: #7A5A00;
  }

  .award-badge.finalist {
    background: var(--accent-light);
    color: var(--accent);
  }

  .award-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--black);
    margin-bottom: 4px;
  }

  .award-subtitle {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--black);
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .award-context {
    font-size: 0.78rem;
    color: var(--grey-text);
    letter-spacing: 0.03em;
  }

  /* ── HOME CONTACT STRIP ── */
  .home-contact-strip {
    padding: 72px 0 80px;
    border-bottom: 1px solid var(--grey-mid);
  }

  .home-contact-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 48px;
    flex-wrap: wrap;
  }

  .home-contact-label {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .home-contact-heading {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 300;
    line-height: 1.25;
    color: var(--black);
  }

  .home-contact-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .home-contact-actions .btn-secondary { margin-left: 0; }

  /* ── UTILITY ── */
  .accent { color: var(--accent); }
  .mt-80 { margin-top: 80px; }
  .pb-120 { padding-bottom: 120px; }

  /* ── REPORT CASE STUDY ── */

  .report-page { padding-top: 120px; }

  .report-header {
    padding: 72px 0 64px;
    border-bottom: 1px solid var(--grey-mid);
  }

  .report-programme {
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .report-programme::before { content: ''; width: 28px; height: 1px; background: var(--accent); }

  .report-h1 {
    font-family: var(--serif);
    font-size: clamp(2.6rem, 5.5vw, 4.8rem);
